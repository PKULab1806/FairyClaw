# Copied to `.env` for local `npm run dev`. Vite exposes only variables prefixed with VITE_.
# For production builds, set the same variables in the build environment — values are baked in at `npm run build` time.

VITE_GATEWAY_BASE_URL=http://127.0.0.1:8081
VITE_API_TOKEN=sk-fairyclaw-dev-token
# Optional:
# VITE_APP_TITLE=FairyClaw
# VITE_APP_VERSION=0.1.0
