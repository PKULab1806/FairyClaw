{
  "name": "RagHooks",
  "description": "Retrieval hooks for RAG indexing and recall.",
  "always_enable_planner": true,
  "always_enable_subagent": true,
  "manifest_version": "1.1",
  "capabilities": [],
  "hooks": [
    {
      "name": "rag_retrieval",
      "stage": "before_llm_call",
      "script": "rag_retrieval.py",
      "priority": 90,
      "enabled": true,
      "timeout_ms": 5000,
      "on_error": "continue",
      "config": {}
    }
  ]
}
