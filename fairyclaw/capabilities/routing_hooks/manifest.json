{
  "name": "RoutingHooks",
  "description": "Routing hooks for follow-up and capability routing decisions.",
  "always_enable_planner": true,
  "always_enable_subagent": true,
  "manifest_version": "1.1",
  "capabilities": [],
  "hooks": [
    {
      "name": "turn_routing",
      "stage": "after_llm_response",
      "script": "turn_routing.py",
      "priority": 100,
      "enabled": true,
      "timeout_ms": 300,
      "on_error": "continue",
      "config": {}
    }
  ]
}
