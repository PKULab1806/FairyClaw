{
  "name": "MemoryHooks",
  "description": "Session memory lifecycle hooks for extraction and compaction.",
  "always_enable_planner": true,
  "always_enable_subagent": true,
  "manifest_version": "1.1",
  "capabilities": [],
  "hooks": [
    {
      "name": "memory_pre_context",
      "stage": "before_llm_call",
      "script": "memory_pre_context.py",
      "priority": 120,
      "enabled": true,
      "timeout_ms": 15000,
      "on_error": "continue",
      "config": {}
    },
    {
      "name": "memory_extraction",
      "stage": "after_llm_response",
      "script": "memory_extraction.py",
      "priority": 100,
      "enabled": true,
      "timeout_ms": 90000,
      "on_error": "continue",
      "config": {}
    }
  ]
}
