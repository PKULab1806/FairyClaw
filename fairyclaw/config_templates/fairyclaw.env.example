# ── Core Process ──────────────────────────────────────────────────────────────
FAIRYCLAW_API_TOKEN=replace_with_strong_token
FAIRYCLAW_DATABASE_URL=sqlite+aiosqlite:///./data/fairyclaw.db
FAIRYCLAW_DATA_DIR=./data
FAIRYCLAW_HOST=0.0.0.0
FAIRYCLAW_PORT=16000
FAIRYCLAW_LLM_ENDPOINTS_CONFIG_PATH=./config/llm_endpoints.yaml
FAIRYCLAW_FILESYSTEM_ROOT_DIR=/path/to/your/workspace
FAIRYCLAW_LOG_LEVEL=INFO
FAIRYCLAW_LOG_FILE_PATH=./data/logs/fairyclaw.log
FAIRYCLAW_LOG_TO_STDOUT=true
FAIRYCLAW_CAPABILITIES_DIR=./fairyclaw/capabilities

# ── Runtime / Scheduling ──────────────────────────────────────────────────────
FAIRYCLAW_EVENT_BUS_WORKER_COUNT=5
FAIRYCLAW_PLANNER_HEARTBEAT_SECONDS=15
FAIRYCLAW_PLANNER_WAKEUP_DEBOUNCE_MS=200
FAIRYCLAW_ROUTER_PROFILE_NAME=router
FAIRYCLAW_HOOK_DEFAULT_TIMEOUT_MS=300
FAIRYCLAW_ENABLE_HOOK_RUNTIME=false
FAIRYCLAW_REINS_ENABLED=true
FAIRYCLAW_REINS_BUDGET_DAILY_USD=100.0
FAIRYCLAW_REINS_ON_EXCEED=reject
FAIRYCLAW_ENABLE_RAG_PIPELINE=false

# ── Capability Group: core_ops ────────────────────────────────────────────────
# New-style key (preferred): FAIRYCLAW_CAP_CORE_OPS__EXECUTION_TIMEOUT_SECONDS
FAIRYCLAW_CAP_CORE_OPS__EXECUTION_TIMEOUT_SECONDS=60
# Deprecated legacy key (transition period, will be removed in a future release):
# FAIRYCLAW_EXECUTION_TIMEOUT_SECONDS=60

# ── Capability Group: web_tools / sourced_research ────────────────────────────
# New-style key (preferred): FAIRYCLAW_CAP_WEB_TOOLS__WEB_PROXY
FAIRYCLAW_CAP_WEB_TOOLS__WEB_PROXY=
FAIRYCLAW_CAP_SOURCED_RESEARCH__WEB_PROXY=
# Deprecated legacy key (transition period, will be removed in a future release):
# FAIRYCLAW_WEB_PROXY=

# ── Capability Group: compression_hooks (optional) ──────────────────
FAIRYCLAW_CONTEXT_TOKEN_BUDGET=0

# ── Gateway / Bridge ──────────────────────────────────────────────────────────
FAIRYCLAW_BRIDGE_TOKEN=fairyclaw-bridge-dev-token
FAIRYCLAW_GATEWAY_PORT=8081
FAIRYCLAW_GATEWAY_BRIDGE_URL=ws://127.0.0.1:16000/internal/gateway/ws

# ── OneBot Gateway ────────────────────────────────────────────────────────────
ONEBOT_API_BASE=http://localhost:3000
ONEBOT_ACCESS_TOKEN=
ONEBOT_ALLOWED_USER=
ONEBOT_SESSION_CMD_PREFIX=/sess
